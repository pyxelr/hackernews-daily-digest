# Copy to .env for local runs. In GitHub Actions, set these as repository secrets
# instead (Settings -> Secrets and variables -> Actions).

# --- Google Gemini (get a free key: https://aistudio.google.com/apikey) ---
# Discover valid model names for your key: python -m src.list_models
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-3.5-flash

# --- Gmail SMTP (use an App Password, not your login password) ---
# https://myaccount.google.com/apppasswords  (requires 2-Step Verification)
GMAIL_USERNAME=you@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
# Comma-separated. Leave blank to email yourself (GMAIL_USERNAME).
RECIPIENTS=

# --- Digest behaviour (optional; sensible defaults shown) ---
NUM_STORIES=30
MIN_SCORE=0
MAX_COMMENTS=6
# Stories summarized per Gemini request (fewer requests = safer vs rate limits).
BATCH_SIZE=8

# --- Article fetching (optional) ---
FETCH_ARTICLES=true
ARTICLE_TIMEOUT=12
ARTICLE_CHAR_LIMIT=6000
FETCH_WORKERS=8

# --- Gemini rate limiting for the free tier (optional) ---
REQUEST_DELAY_SECONDS=6
MAX_RETRIES=4

# --- Run mode ---
# true = write output/digest.html instead of sending an email (great for testing)
DRY_RUN=false
